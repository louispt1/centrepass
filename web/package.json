{
  "name": "centrepass-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/netball-wasm --target web --out-dir ../../web/src/wasm --out-name netball",
    "build:types": "TS_RS_EXPORT_DIR=../../web/src/types cargo test -p netball-core --features ts-bindings --quiet export_bindings",
    "dev": "npm run build:wasm && npm run build:types && vite",
    "build": "npm run build:wasm && npm run build:types && tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "test": "playwright test",
    "screenshots": "SCREENSHOTS=1 playwright test screenshots"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
